# See vtk-config.cmake.in for why the data directory is globbed rather than
# addressed by the package version.
file(GLOB _fvtk_sdk_data_dir LIST_DIRECTORIES true
  "${CMAKE_CURRENT_LIST_DIR}/../@VTK_SDK_INSTALL_DIR@/vtk-*.data")
list(GET _fvtk_sdk_data_dir 0 _fvtk_sdk_data_dir)
include("${_fvtk_sdk_data_dir}/headers/cmake/vtk-config-version.cmake")
unset(_fvtk_sdk_data_dir)
